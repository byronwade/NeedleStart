    "build:json": "bun ../../packages/cli/src/index.ts build . --json",
    "start": "bun ../../packages/cli/src/index.ts start .",
    "start:once": "bun ../../packages/cli/src/index.ts start . --once",
    "routes": "bun ../../packages/cli/src/index.ts routes . --json",
